# Demo Mode (set both to 'true' to run without Jira/GitHub credentials)
# DEMO_MODE=true
# VITE_DEMO_MODE=true

# Jira Cloud Configuration (not needed in demo mode)
# The Node API server must reach JIRA_HOST (DNS + HTTPS). ENOTFOUND usually means no DNS/VPN/offline from the machine running dev-server, not a bad token.
JIRA_EMAIL=you@redhat.com
JIRA_TOKEN=your-jira-api-token
JIRA_HOST=https://redhat.atlassian.net

# GitHub personal access token (for contribution stats)
GITHUB_TOKEN=your-github-pat

# Admin emails (comma-separated, used to seed the allowlist)
ADMIN_EMAILS=you@redhat.com

# Auth email domain override (optional)
# If your OAuth proxy rewrites user emails to a different domain (e.g. cluster.local),
# set this so role assignments match the authenticated email domain.
# AUTH_EMAIL_DOMAIN=

# API Endpoint (optional — defaults to /api, which Vite proxies to the dev server on port 3001)
# Use a full URL only if the UI and API are on different origins. Include /api if you point at the
# server root, or set only the origin (e.g. http://localhost:3001) — /api is appended automatically.
# VITE_API_ENDPOINT=

# GitLab Configuration (optional)
# Configure instances via the Settings UI. Each instance references a token env var by name.
# GITLAB_TOKEN=           # Default token for GitLab.com (referenced as tokenEnvVar: "GITLAB_TOKEN" in Settings)
# GITLAB_BASE_URL=        # Optional legacy setting, defaults to https://gitlab.com (prefer Settings UI)
# GITLAB_TOKEN_INTERNAL=  # Example: token for an additional internal GitLab instance

# Feature Traffic GitLab token (optional - overrides GITLAB_TOKEN for CI artifact fetching)
# Only needed if the feature-traffic pipeline project requires a different token
# Use a PAT with read_api scope
# FEATURE_TRAFFIC_GITLAB_TOKEN=

# Local dev server port (optional - defaults to 3001)
# API_PORT=3001

# Proxy auth secret (optional - when set, backend requires X-Proxy-Secret header)
# Used in production: nginx injects this header when proxying to the backend.
# PROXY_AUTH_SECRET=

# IPA LDAP (for roster sync — requires VPN)
# IPA_BIND_DN=uid=svc-account,cn=users,cn=accounts,dc=ipa,dc=redhat,dc=com
# IPA_BIND_PASSWORD=

# Google Sheets service account key file (for roster sync)
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/google-sa-key.json

# Upstream Pulse API URL (optional - for the upstream-pulse module)
# Defaults to in-cluster service URL. Set for local dev when port-forwarding.
# UPSTREAM_PULSE_API_URL=http://localhost:4321

# Product Pages OAuth (production — service account)
# PRODUCT_PAGES_CLIENT_ID=
# PRODUCT_PAGES_CLIENT_SECRET=
# Product Pages personal token (local dev fallback)
# PRODUCT_PAGES_TOKEN=

# Release Analysis: Extra JQL filters for velocity queries, keyed by project. JSON object.
# Default: {"AIPCC":"issuetype = Epic AND labels = package"}
# RELEASE_ANALYSIS_VELOCITY_EXTRA_JQL_BY_PROJECT={"AIPCC":"issuetype = Epic AND labels = package"}

# Release Analysis: Target Version only (not Fix version). REST field id default: customfield_10855; default JQL: cf[10855] is not EMPTY.
# If RELEASE_ANALYSIS_TARGET_VERSION_FIELD is customfield_NNN, default JQL is cf[NNN] is not EMPTY unless you override below.
# RELEASE_ANALYSIS_TARGET_VERSION_FIELD=customfield_10855
# Optional JQL override (otherwise derived from custom field id or name-based fallback when unset):
# RELEASE_ANALYSIS_TARGET_VERSION_JQL_FRAGMENT=cf[10855] is not EMPTY

# SmartSheet (for release-planning module -- release discovery)
# SMARTSHEET_API_TOKEN=your-smartsheet-api-token
# SMARTSHEET_SHEET_ID=3025228340193156
