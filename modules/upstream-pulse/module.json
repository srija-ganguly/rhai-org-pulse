{
  "name": "Upstream Pulse",
  "slug": "upstream-pulse",
  "description": "Upstream open-source contribution insights across GitHub organizations",
  "icon": "activity",
  "order": 10,
  "client": {
    "entry": "./client/index.js",
    "navItems": [
      { "id": "dashboard", "label": "Dashboard", "icon": "BarChart3", "default": true },
      { "id": "insights", "label": "Insights", "icon": "Lightbulb" },
      { "id": "portfolio", "label": "Portfolio", "icon": "Briefcase" },
      { "id": "strategy", "label": "Strategy", "icon": "Target" }
    ],
    "settingsComponent": "./client/components/UpstreamPulseSettings.vue"
  },
  "server": {
    "entry": "./server/index.js"
  },
  "secrets": {
    "module": [
      {
        "key": "GITLAB_TOKEN",
        "description": "GitLab PAT with read_api scope for fetching team data",
        "required": false
      },
      {
        "key": "GITLAB_TEAM_DATA_PROJECT_ID",
        "description": "GitLab project ID containing github-access.json",
        "required": false
      }
    ]
  },
  "defaultEnabled": false,
  "requires": []
}
