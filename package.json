{
  "name": "team-tracker",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "dev:server": "node -r dotenv/config server/dev-server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "validate:modules": "node scripts/validate-modules.js",
    "validate:openapi": "node scripts/validate-openapi.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chart.js": "^4.4.7",
    "driver.js": "^1.4.0",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "https-proxy-agent": "^7.0.6",
    "ldapjs": "^3.0.7",
    "lucide-vue-next": "^0.577.0",
    "node-fetch": "^2.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.13",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.4",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.49",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,vue}": "eslint --fix"
  }
}
