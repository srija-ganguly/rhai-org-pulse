{
  "name": "team-tracker",
  "private": true,
  "version": "1.0.127",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node -r dotenv/config server/dev-server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test tests/smoke",
    "test:integration": "playwright test tests/integration",
    "lint": "eslint .",
    "validate:modules": "node scripts/validate-modules.js",
    "validate:platform": "node scripts/validate-platform.js",
    "validate:openapi": "node scripts/validate-openapi.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@dagrejs/dagre": "^3.0.0",
    "@octokit/rest": "^22.0.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.17",
    "async-retry": "^1.3.3",
    "chart.js": "^4.4.7",
    "compression": "^1.8.1",
    "dompurify": "^3.4.11",
    "driver.js": "^1.5.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^173.0.0",
    "ldapjs": "^3.0.7",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "node-fetch": "^3.3.2",
    "sortablejs": "^1.15.7",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.16",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.16",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,vue}": "eslint --fix"
  }
}
