{
  "name": "org-pulse-ai-eng",
  "private": true,
  "version": "1.0.170",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "vite",
    "dev:server": "node -r dotenv/config server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.mjs",
    "test:watch": "vitest",
    "test:smoke": "playwright test tests/smoke",
    "test:integration": "playwright test tests/integration",
    "lint": "eslint .",
    "validate:modules": "node node_modules/@org-pulse/core/scripts/validate-modules.js",
    "validate:platform": "node node_modules/@org-pulse/core/scripts/validate-platform.js",
    "validate:openapi": "cp scripts/openapi-route-count.json node_modules/@org-pulse/core/scripts/ && node node_modules/@org-pulse/core/scripts/validate-openapi.js",
    "validate:dockerfile-deps": "node scripts/validate-dockerfile-deps.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@octokit/rest": "^22.0.1",
    "@org-pulse/core": "^2.0.13",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.3.0",
    "express": "^5.2.1",
    "js-yaml": "^5.2.1",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,vue}": "eslint --fix"
  }
}
